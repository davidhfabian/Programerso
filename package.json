{
  "name": "programerso",
  "type": "module",
  "version": "0.2.0",
  "description": "Aprendé a programar desde cero y en la era de la IA: código real en el navegador, ejercicios variados, XP, rachas y certificados.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "verify:content": "node --experimental-strip-types scripts/verify-content.mjs",
    "verify": "pnpm run check && pnpm run verify:content && pnpm run build",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test smoke",
    "test:e2e:courses": "playwright test courses"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.5",
    "astro": "^5.12.9",
    "astro-icon": "^1.1.5",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@iconify-json/tabler": "^1.2.20",
    "@playwright/test": "^1.61.0",
    "typescript": "^5.8.3"
  }
}
