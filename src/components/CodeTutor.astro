---
// Editor-tutor interactivo. Guía al alumno paso a paso con varios TIPOS de
// ejercicio: tipeo guiado (ghost text + Tab), tarjeta conceptual, quiz de
// opción múltiple, predecir la salida, arreglar un bug y resolver un reto
// abierto validado por su salida. Ejecuta código real en el navegador
// (JS nativo / Python con Pyodide). Progreso, XP y rachas en localStorage.
import type { Lesson, LearnLanguage } from '~/data/learn';
import { glossary as glossaryAll, lessonGlossary } from '~/data/learn';

export interface Props {
  lesson: Lesson;
  language: LearnLanguage;
  runtimeLabel: string;
  courseSlug: string;
  nextHref?: string;
}

const { lesson, language, runtimeLabel, courseSlug, nextHref } = Astro.props;

// Renderiza [[clave]] o [[clave|texto]] como un botón de glosario.
function renderTerms(text: string): string {
  return text.replace(/\[\[([^\]|]+)(?:\|([^\]]*))?\]\]/g, (_m, rawKey: string, display?: string) => {
    const key = rawKey.trim().toLowerCase();
    const label = (display ?? glossaryAll[key]?.term ?? rawKey).trim();
    return `<button type="button" class="ct-term" data-term="${key}">${label}</button>`;
  });
}

const runnable = language === 'javascript' || language === 'python';

const payload = {
  language,
  runnable,
  runtimeLabel,
  courseSlug,
  lessonSlug: lesson.slug,
  tags: lesson.tags ?? [],
  glossary: lessonGlossary(lesson),
  steps: lesson.steps.map((s) => ({
    kind: s.kind ?? 'type',
    instruction: s.instruction,
    explanationHtml: renderTerms(s.explanation),
    hint: s.hint ?? '',
    revealHtml: s.reveal ? renderTerms(s.reveal) : '',
    solution: s.solution ?? '',
    question: s.question ?? '',
    choices: (s.choices ?? []).map((c) => ({
      textHtml: renderTerms(c.text),
      correct: !!c.correct,
      feedbackHtml: c.feedback ? renderTerms(c.feedback) : '',
    })),
    code: s.code ?? '',
    expectedOutput: s.expectedOutput ?? '',
    buggyCode: s.buggyCode ?? '',
    starter: s.starter ?? '',
    checks: s.checks ?? [],
    referenceSolution: s.referenceSolution ?? '',
  })),
};

const json = JSON.stringify(payload).replace(/</g, '\\u003c');
const stepCount = lesson.steps.length;
const fileExt = language === 'python' ? 'py' : language === 'javascript' ? 'js' : 'txt';
---

<section
  class="ct"
  data-ct
  data-course={courseSlug}
  data-lesson={lesson.slug}
  data-next-href={nextHref}
  aria-label="Editor interactivo"
>
  <script type="application/json" data-ct-data is:inline set:html={json} />

  <div class="ct-grid">
    {/* ── Panel guía ───────────────────────────────────────────── */}
    <aside class="ct-guide">
      <div class="ct-progress">
        <div class="ct-progress-meta">
          <span class="ct-progress-label">Paso <span data-ct-step-num>1</span> / {stepCount}</span>
          <span class="ct-kind-badge" data-ct-kind-badge hidden></span>
          <span class="ct-progress-pct" data-ct-pct>0%</span>
        </div>
        <div class="ct-progress-track" role="progressbar" aria-label="Progreso de la lección">
          <div class="ct-progress-fill" data-ct-fill></div>
        </div>
      </div>

      <p class="ct-instruction" data-ct-instruction></p>
      <div class="ct-explanation" data-ct-explanation></div>

      {/* Sugerencia de tipeo (kind: type) */}
      <div class="ct-suggest" data-ct-suggest hidden>
        <span class="ct-suggest-label">Siguiente:</span>
        <button type="button" class="ct-suggest-chip" data-ct-suggest-chip></button>
        <span class="ct-suggest-tab">o <kbd>Tab</kbd></span>
      </div>

      {/* Opciones (kind: quiz / predict-mc) */}
      <div class="ct-choices" data-ct-choices hidden role="group" aria-label="Opciones"></div>

      {/* Entrada de predicción de texto (kind: predict libre) */}
      <div class="ct-predict" data-ct-predict hidden>
        <label class="ct-predict-label" for={`ct-predict-${lesson.slug}`}>Escribí la salida exacta:</label>
        <textarea
          id={`ct-predict-${lesson.slug}`}
          class="ct-predict-input font-mono"
          data-ct-predict-input
          rows="2"
          spellcheck="false"
          placeholder="¿Qué imprime el programa?"></textarea>
      </div>

      {/* Retroalimentación (quiz/predict resueltos) */}
      <div class="ct-feedback" data-ct-feedback hidden></div>

      <div class="ct-hint" data-ct-hint hidden></div>

      <div class="ct-actions">
        <button type="button" class="ct-btn ct-btn-ghost" data-ct-hint-btn>Pista</button>
        <button type="button" class="ct-btn ct-btn-ghost" data-ct-reveal-btn hidden>Ver solución</button>
        <button type="button" class="ct-btn ct-btn-primary" data-ct-primary>Comprobar</button>
      </div>
    </aside>

    {/* ── Editor + consola ─────────────────────────────────────── */}
    <div class="ct-editor">
      <div class="ct-toolbar">
        <span class="ct-dots" aria-hidden="true"><span></span><span></span><span></span></span>
        <span class="ct-runtime font-mono" data-ct-runtime>{runtimeLabel} · lección.{fileExt}</span>
        <button type="button" class="ct-reset" data-ct-reset title="Reiniciar lección" aria-label="Reiniciar lección">
          ↺
        </button>
      </div>

      <div class="ct-code" data-ct-code>
        <div class="ct-accepted font-mono" data-ct-accepted></div>

        {/* Input activo (kind: type) */}
        <div class="ct-active font-mono" data-ct-active-wrap>
          <span class="ct-gutter" aria-hidden="true">›</span>
          <div class="ct-field">
            <div class="ct-mirror" aria-hidden="true"><span class="ct-typed"></span><span class="ct-ghost"></span></div>
            <input
              class="ct-input"
              data-ct-input
              type="text"
              spellcheck="false"
              autocomplete="off"
              autocapitalize="off"
              autocorrect="off"
              aria-label="Escribí el código de este paso"
            />
          </div>
        </div>

        {/* Editor libre (kind: fix / challenge) */}
        <div class="ct-free" data-ct-free hidden>
          <textarea
            class="ct-free-input font-mono"
            data-ct-free-input
            spellcheck="false"
            autocomplete="off"
            autocapitalize="off"
            autocorrect="off"
            aria-label="Editá el código"></textarea>
        </div>

        {/* Código en sólo lectura (kind: predict / info) */}
        <pre class="ct-readonly font-mono" data-ct-readonly hidden></pre>
      </div>

      <div class="ct-console">
        <div class="ct-console-head font-mono">
          <span>salida</span>
          <button type="button" class="ct-run" data-ct-run hidden>▶ Ejecutar</button>
        </div>
        <pre class="ct-console-out font-mono" data-ct-out aria-live="polite"></pre>
        <ul class="ct-checks" data-ct-checks hidden></ul>
      </div>
    </div>
  </div>

  {/* ── Estado completado ──────────────────────────────────────── */}
  <div class="ct-done" data-ct-done hidden>
    <span class="ct-done-check" aria-hidden="true">✓</span>
    <div class="ct-done-text">
      <p class="ct-done-title">¡Lección completada!</p>
      <p class="ct-done-sub" data-ct-done-sub>Sumaste XP. Seguí con la próxima lección cuando quieras.</p>
    </div>
    <a class="ct-done-next" data-ct-done-next hidden href="#">Siguiente lección →</a>
  </div>

  {/* Tooltip de glosario compartido */}
  <div class="ct-tip" data-ct-tip role="tooltip" hidden>
    <span class="ct-tip-term" data-ct-tip-term></span>
    <span class="ct-tip-def" data-ct-tip-def></span>
  </div>
</section>

<style>
  .ct {
    --ct-accent: var(--aw-color-primary);
    position: relative;
    border: 1px solid var(--aw-color-border);
    border-radius: 14px;
    background: var(--aw-color-bg-surface);
    overflow: hidden;
  }

  .ct-grid {
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .ct-grid {
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    }
  }

  /* ── Guía ─────────────────────────────────────────────────── */
  .ct-guide {
    padding: 1.25rem 1.35rem;
    border-bottom: 1px solid var(--aw-color-border);
  }
  @media (min-width: 900px) {
    .ct-guide {
      border-bottom: none;
      border-right: 1px solid var(--aw-color-border);
    }
  }

  .ct-progress {
    margin-bottom: 1.1rem;
  }
  .ct-progress-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-geist-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--aw-color-text-tertiary);
    margin-bottom: 0.45rem;
  }
  .ct-progress-label {
    flex: 1;
  }
  .ct-kind-badge {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.62rem;
    padding: 0.1rem 0.42rem;
    border-radius: 999px;
    border: 1px solid var(--turquoise-border);
    background: var(--turquoise-bg);
    color: var(--ct-accent);
  }
  .ct-progress-pct {
    font-variant-numeric: tabular-nums;
  }
  .ct-progress-track {
    height: 3px;
    border-radius: 999px;
    background: var(--aw-color-border);
    overflow: hidden;
  }
  .ct-progress-fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: var(--ct-accent);
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ct-instruction {
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--aw-color-text-default);
    margin: 0 0 0.6rem;
  }
  .ct-explanation {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
  }
  .ct-explanation :global(code),
  .ct-feedback :global(code),
  .ct-choices :global(code) {
    font-family: var(--font-geist-mono);
    font-size: 0.82em;
    padding: 0.08em 0.35em;
    border-radius: 5px;
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    color: var(--aw-color-text-default);
  }
  .ct-explanation :global(strong) {
    color: var(--aw-color-text-default);
    font-weight: 600;
  }

  /* Término de glosario */
  .ct-explanation :global(.ct-term),
  .ct-feedback :global(.ct-term),
  .ct-choices :global(.ct-term) {
    font: inherit;
    color: var(--aw-color-text-default);
    border: none;
    background: none;
    padding: 0;
    cursor: help;
    border-bottom: 1px dashed var(--turquoise-border);
    transition: color 0.2s ease;
  }
  .ct-explanation :global(.ct-term:hover),
  .ct-explanation :global(.ct-term:focus-visible) {
    color: var(--ct-accent);
    outline: none;
  }

  .ct-suggest {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
    font-size: 0.78rem;
    color: var(--aw-color-text-tertiary);
  }
  .ct-suggest-chip {
    font-family: var(--font-geist-mono);
    font-size: 0.78rem;
    color: var(--aw-color-text-default);
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border-hover);
    border-radius: 6px;
    padding: 0.2rem 0.5rem;
    cursor: pointer;
    transition: all 0.18s ease;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ct-suggest-chip:hover {
    border-color: var(--ct-accent);
    box-shadow: 0 0 0 1px var(--turquoise-border);
  }
  .ct-suggest-tab kbd {
    font-family: var(--font-geist-mono);
    font-size: 0.68rem;
    border: 1px solid var(--aw-color-border-hover);
    border-radius: 4px;
    padding: 0.05rem 0.3rem;
  }

  /* ── Opciones (quiz / predict) ────────────────────────────── */
  .ct-choices {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.1rem;
  }
  .ct-choice {
    text-align: left;
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--aw-color-text-default);
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    border-radius: 10px;
    padding: 0.7rem 0.85rem;
    cursor: pointer;
    transition: all 0.15s ease;
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .ct-choice:hover:not(:disabled) {
    border-color: var(--aw-color-border-hover);
    transform: translateX(2px);
  }
  .ct-choice-key {
    flex: 0 0 auto;
    width: 1.4rem;
    height: 1.4rem;
    display: grid;
    place-items: center;
    border-radius: 6px;
    border: 1px solid var(--aw-color-border);
    font-family: var(--font-geist-mono);
    font-size: 0.72rem;
    color: var(--aw-color-text-tertiary);
  }
  .ct-choice.is-correct {
    border-color: var(--turquoise-border);
    background: var(--turquoise-bg);
  }
  .ct-choice.is-correct .ct-choice-key {
    border-color: var(--turquoise-border);
    color: var(--ct-accent);
  }
  .ct-choice.is-wrong {
    border-color: rgba(239, 68, 68, 0.5);
    background: rgba(239, 68, 68, 0.06);
  }
  .ct-choice.is-wrong .ct-choice-key {
    border-color: rgba(239, 68, 68, 0.5);
    color: #ef4444;
  }
  .ct-choice:disabled {
    cursor: default;
  }
  .ct-choice :global(pre) {
    margin: 0;
    white-space: pre-wrap;
  }

  /* ── Predicción de texto ──────────────────────────────────── */
  .ct-predict {
    margin-top: 1.1rem;
  }
  .ct-predict-label {
    display: block;
    font-size: 0.76rem;
    color: var(--aw-color-text-tertiary);
    margin-bottom: 0.4rem;
  }
  .ct-predict-input {
    width: 100%;
    resize: vertical;
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    border-radius: 8px;
    padding: 0.55rem 0.7rem;
    color: var(--aw-color-text-default);
    font-size: 0.85rem;
    line-height: 1.5;
    outline: none;
  }
  .ct-predict-input:focus {
    border-color: var(--ct-accent);
  }

  /* ── Retroalimentación ────────────────────────────────────── */
  .ct-feedback {
    margin-top: 1rem;
    font-size: 0.85rem;
    line-height: 1.55;
    padding: 0.7rem 0.85rem;
    border-radius: 8px;
    border-left: 2px solid var(--aw-color-border-hover);
    background: var(--aw-color-bg-page);
    color: var(--aw-color-text-muted);
  }
  .ct-feedback.is-ok {
    border-left-color: var(--turquoise-border);
    background: var(--turquoise-bg);
  }
  .ct-feedback.is-bad {
    border-left-color: rgba(239, 68, 68, 0.5);
    background: rgba(239, 68, 68, 0.06);
  }
  .ct-feedback-title {
    font-weight: 600;
    color: var(--aw-color-text-default);
    display: block;
    margin-bottom: 0.2rem;
  }

  .ct-hint {
    margin-top: 0.9rem;
    font-size: 0.83rem;
    line-height: 1.5;
    color: var(--aw-color-text-muted);
    padding: 0.6rem 0.75rem;
    border-left: 2px solid var(--turquoise-border);
    background: var(--turquoise-bg);
    border-radius: 0 6px 6px 0;
  }

  .ct-actions {
    display: flex;
    gap: 0.55rem;
    margin-top: 1.2rem;
    flex-wrap: wrap;
  }
  .ct-btn {
    font-family: var(--font-geist-sans);
    font-size: 0.85rem;
    font-weight: 500;
    border-radius: 8px;
    padding: 0.5rem 1rem;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.18s ease;
  }
  .ct-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .ct-btn-ghost {
    background: transparent;
    color: var(--aw-color-text-muted);
    border-color: var(--aw-color-border);
  }
  .ct-btn-ghost:hover {
    color: var(--aw-color-text-default);
    border-color: var(--aw-color-border-hover);
  }
  .ct-btn-primary {
    background: var(--aw-color-bg-page);
    color: var(--aw-color-text-default);
    border-color: var(--aw-color-border-hover);
    position: relative;
  }
  .ct-btn-primary:hover {
    border-color: var(--ct-accent);
    box-shadow: 0 0 18px var(--turquoise-glow);
  }

  /* ── Editor ───────────────────────────────────────────────── */
  .ct-editor {
    display: flex;
    flex-direction: column;
    background: var(--aw-color-bg-page);
    min-width: 0;
  }
  .ct-toolbar {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid var(--aw-color-border);
  }
  .ct-dots {
    display: inline-flex;
    gap: 6px;
  }
  .ct-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--aw-color-border-hover);
  }
  .ct-runtime {
    font-size: 0.74rem;
    color: var(--aw-color-text-tertiary);
    flex: 1;
  }
  .ct-reset {
    background: none;
    border: none;
    color: var(--aw-color-text-tertiary);
    font-size: 1.05rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.2rem 0.4rem;
    border-radius: 6px;
    transition: color 0.18s ease;
  }
  .ct-reset:hover {
    color: var(--aw-color-text-default);
  }

  .ct-code {
    padding: 0.85rem 0.5rem 0.85rem 0;
    min-height: 168px;
    font-size: 0.86rem;
    line-height: 1.75;
    overflow-x: auto;
  }
  .ct-line,
  .ct-active {
    display: flex;
    align-items: flex-start;
    white-space: pre;
  }
  .ct-ln {
    flex: 0 0 2.4rem;
    text-align: right;
    padding-right: 0.85rem;
    color: var(--aw-color-text-tertiary);
    opacity: 0.55;
    user-select: none;
  }
  .ct-line-code {
    color: var(--aw-color-text-default);
    white-space: pre;
  }
  .ct-line-check {
    margin-left: 0.6rem;
    color: var(--ct-accent);
  }

  .ct-active {
    position: relative;
  }
  .ct-gutter {
    flex: 0 0 2.4rem;
    text-align: right;
    padding-right: 0.85rem;
    color: var(--ct-accent);
    user-select: none;
  }
  .ct-field {
    position: relative;
    flex: 1;
    min-width: 0;
  }
  .ct-mirror,
  .ct-input {
    font-family: var(--font-geist-mono);
    font-size: 0.86rem;
    line-height: 1.75;
    white-space: pre;
    padding: 0;
    margin: 0;
    border: none;
  }
  .ct-mirror {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .ct-typed {
    color: var(--aw-color-text-default);
  }
  .ct-ghost {
    color: var(--aw-color-text-tertiary);
    opacity: 0.6;
  }
  .ct-input {
    position: relative;
    width: 100%;
    background: transparent;
    color: transparent;
    caret-color: var(--ct-accent);
    outline: none;
  }
  .ct-field.is-mismatch .ct-typed {
    color: #ef4444;
  }
  .ct-active.is-shake {
    animation: ct-shake 0.4s ease-in-out;
  }
  @keyframes ct-shake {
    0%,
    100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-4px);
    }
    75% {
      transform: translateX(4px);
    }
  }

  /* Editor libre */
  .ct-free {
    padding: 0 0.6rem 0 0.9rem;
  }
  .ct-free-input {
    width: 100%;
    min-height: 9rem;
    resize: vertical;
    background: transparent;
    border: none;
    outline: none;
    color: var(--aw-color-text-default);
    font-size: 0.86rem;
    line-height: 1.75;
    white-space: pre;
    overflow-wrap: normal;
    tab-size: 2;
  }

  /* Código en sólo lectura */
  .ct-readonly {
    margin: 0;
    padding: 0 0.9rem;
    color: var(--aw-color-text-default);
    font-size: 0.86rem;
    line-height: 1.75;
    white-space: pre;
    overflow-x: auto;
  }

  /* ── Consola ──────────────────────────────────────────────── */
  .ct-console {
    border-top: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-surface);
  }
  .ct-console-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--aw-color-text-tertiary);
    padding: 0.5rem 0.9rem;
    border-bottom: 1px solid var(--aw-color-border);
  }
  .ct-run {
    font-family: var(--font-geist-mono);
    font-size: 0.72rem;
    text-transform: none;
    letter-spacing: 0;
    color: var(--aw-color-text-muted);
    background: none;
    border: 1px solid var(--aw-color-border);
    border-radius: 6px;
    padding: 0.15rem 0.5rem;
    cursor: pointer;
  }
  .ct-run:hover {
    color: var(--ct-accent);
    border-color: var(--ct-accent);
  }
  .ct-console-out {
    margin: 0;
    padding: 0.75rem 0.9rem;
    min-height: 2.6rem;
    max-height: 11rem;
    overflow: auto;
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
    white-space: pre-wrap;
    word-break: break-word;
  }
  .ct-out-err {
    color: #ef4444;
  }
  .ct-out-muted {
    color: var(--aw-color-text-tertiary);
    font-style: italic;
  }
  .ct-checks {
    list-style: none;
    margin: 0;
    padding: 0 0.9rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .ct-check {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--aw-color-text-muted);
  }
  .ct-check-mark {
    flex: 0 0 auto;
    width: 1.05rem;
    height: 1.05rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 1px solid var(--aw-color-border-hover);
    font-size: 0.62rem;
  }
  .ct-check.is-pass {
    color: var(--aw-color-text-default);
  }
  .ct-check.is-pass .ct-check-mark {
    border-color: var(--turquoise-border);
    color: var(--ct-accent);
    background: var(--turquoise-bg);
  }
  .ct-check.is-fail .ct-check-mark {
    color: var(--aw-color-text-tertiary);
  }

  /* ── Completado ───────────────────────────────────────────── */
  .ct-done {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1rem 1.35rem;
    border-top: 1px solid var(--aw-color-border);
    background: var(--turquoise-bg);
    animation: fadeIn 0.5s ease both;
  }
  .ct-done-check {
    flex: 0 0 auto;
    width: 1.9rem;
    height: 1.9rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 1px solid var(--turquoise-border);
    color: var(--ct-accent);
    font-size: 0.95rem;
  }
  .ct-done-text {
    flex: 1;
  }
  .ct-done-title {
    font-weight: 600;
    color: var(--aw-color-text-default);
    margin: 0;
  }
  .ct-done-sub {
    font-size: 0.83rem;
    color: var(--aw-color-text-muted);
    margin: 0.1rem 0 0;
  }
  .ct-done-next {
    flex: 0 0 auto;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ct-accent);
    border: 1px solid var(--turquoise-border);
    border-radius: 8px;
    padding: 0.45rem 0.85rem;
    transition: all 0.18s ease;
  }
  .ct-done-next:hover {
    background: var(--aw-color-bg-page);
    box-shadow: 0 0 16px var(--turquoise-glow);
  }

  /* ── Tooltip ──────────────────────────────────────────────── */
  .ct-tip {
    position: fixed;
    z-index: 60;
    max-width: 280px;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border-hover);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
    pointer-events: none;
    animation: ct-tip-in 0.16s ease both;
  }
  @keyframes ct-tip-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .ct-tip-term {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ct-accent);
    margin-bottom: 0.2rem;
  }
  .ct-tip-def {
    display: block;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--aw-color-text-default);
  }

  @media (prefers-reduced-motion: reduce) {
    .ct-progress-fill,
    .ct-active.is-shake,
    .ct-done,
    .ct-tip,
    .ct-choice {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  import { runJs, runPy, normalizeOutput, evaluateChecks } from '../lib/runner';
  import type { Check } from '../lib/runner';
  import {
    addXp,
    XP,
    setStepIndex,
    clearLesson,
    markLessonDone,
    unlock,
    bumpCounter,
    getLevelInfo,
    liveStreak,
    gradeReview,
  } from '../lib/store';

  // ── Tipos del payload ──────────────────────────────────────────
  type Kind = 'type' | 'info' | 'quiz' | 'predict' | 'fix' | 'challenge';
  type Choice = { textHtml: string; correct: boolean; feedbackHtml: string };
  type Step = {
    kind: Kind;
    instruction: string;
    explanationHtml: string;
    hint: string;
    revealHtml: string;
    solution: string;
    question: string;
    choices: Choice[];
    code: string;
    expectedOutput: string;
    buggyCode: string;
    starter: string;
    checks: Check[];
    referenceSolution: string;
  };
  type GlossaryMap = Record<string, { term: string; definition: string }>;
  type Payload = {
    language: 'javascript' | 'python' | 'none';
    runnable: boolean;
    runtimeLabel: string;
    courseSlug: string;
    lessonSlug: string;
    tags: string[];
    glossary: GlossaryMap;
    steps: Step[];
  };
  type RunResult = { ok: boolean; output: string; incomplete?: boolean; loadFailed?: boolean };

  const KIND_LABEL: Record<Kind, string> = {
    type: 'Escribir',
    info: 'Concepto',
    quiz: 'Quiz',
    predict: 'Predecir',
    fix: 'Depurar',
    challenge: 'Reto',
  };

  // Inserta HTML CONFIABLE (currículum autoral, nunca input del alumno) de forma
  // segura: lo parsea en un documento inerte con DOMParser (los scripts no se
  // ejecutan) y adopta los nodos. El código del alumno jamás pasa por acá.
  function setHTML(el: Element, markup: string): void {
    el.replaceChildren();
    if (!markup) return;
    const parsed = new DOMParser().parseFromString(markup, 'text/html');
    el.append(...Array.from(parsed.body.childNodes));
  }

  // ── Utilidades ────────────────────────────────────────────────
  const norm = (s: string) => s.replace(/\s+$/g, '');
  const leadingWs = (s: string) => s.match(/^\s*/)?.[0] ?? '';

  // Próximo "trozo" a tipear: espacios iniciales + un token.
  function nextChunk(remaining: string): string {
    const m = remaining.match(/^(\s*)("[^"]*"|'[^']*'|`[^`]*`|\w+|[^\w\s])/);
    return m ? m[0] : remaining;
  }

  async function runProgram(language: string, code: string): Promise<RunResult> {
    return language === 'python' ? runPy(code) : runJs(code);
  }

  // ── Controlador de una instancia ──────────────────────────────
  function initTutor(root: HTMLElement) {
    if (root.dataset.ctReady === '1') return;
    root.dataset.ctReady = '1';

    const dataEl = root.querySelector<HTMLScriptElement>('[data-ct-data]');
    if (!dataEl?.textContent) return;
    const data: Payload = JSON.parse(dataEl.textContent);

    const $ = <T extends HTMLElement = HTMLElement>(sel: string) => root.querySelector<T>(sel);
    const stepNumEl = $('[data-ct-step-num]')!;
    const kindBadge = $('[data-ct-kind-badge]')!;
    const pctEl = $('[data-ct-pct]')!;
    const fillEl = $('[data-ct-fill]')!;
    const instructionEl = $('[data-ct-instruction]')!;
    const explanationEl = $('[data-ct-explanation]')!;
    const suggestEl = $('[data-ct-suggest]')!;
    const suggestChip = $<HTMLButtonElement>('[data-ct-suggest-chip]')!;
    const choicesEl = $('[data-ct-choices]')!;
    const predictEl = $('[data-ct-predict]')!;
    const predictInput = $<HTMLTextAreaElement>('[data-ct-predict-input]')!;
    const feedbackEl = $('[data-ct-feedback]')!;
    const hintEl = $('[data-ct-hint]')!;
    const hintBtn = $<HTMLButtonElement>('[data-ct-hint-btn]')!;
    const revealBtn = $<HTMLButtonElement>('[data-ct-reveal-btn]')!;
    const primaryBtn = $<HTMLButtonElement>('[data-ct-primary]')!;
    const acceptedEl = $('[data-ct-accepted]')!;
    const activeWrap = $('[data-ct-active-wrap]')!;
    const fieldEl = activeWrap.querySelector<HTMLElement>('.ct-field')!;
    const typedEl = activeWrap.querySelector<HTMLElement>('.ct-typed')!;
    const ghostEl = activeWrap.querySelector<HTMLElement>('.ct-ghost')!;
    const input = $<HTMLInputElement>('[data-ct-input]')!;
    const freeWrap = $('[data-ct-free]')!;
    const freeInput = $<HTMLTextAreaElement>('[data-ct-free-input]')!;
    const readonlyEl = $('[data-ct-readonly]')!;
    const resetBtn = $<HTMLButtonElement>('[data-ct-reset]')!;
    const outEl = $('[data-ct-out]')!;
    const runBtn = $<HTMLButtonElement>('[data-ct-run]')!;
    const checksEl = $('[data-ct-checks]')!;
    const doneEl = $('[data-ct-done]')!;
    const doneSub = $('[data-ct-done-sub]')!;
    const doneNext = $<HTMLAnchorElement>('[data-ct-done-next]')!;
    const tipEl = $('[data-ct-tip]')!;
    const tipTerm = $('[data-ct-tip-term]')!;
    const tipDef = $('[data-ct-tip-def]')!;

    const accepted: string[] = [];
    let current = 0;
    let finished = false;
    let wrongThisStep = false;
    let attemptsThisStep = 0;
    let answered = false; // para quiz/predict-mc

    // ── Persistencia de progreso ──────────────────────────────
    function saveStep() {
      setStepIndex(data.courseSlug, data.lessonSlug, current);
    }

    // ── Render del editor (lado derecho) ──────────────────────
    function renderAccepted() {
      acceptedEl.replaceChildren();
      accepted.forEach((line, i) => {
        const row = document.createElement('div');
        row.className = 'ct-line';
        const ln = document.createElement('span');
        ln.className = 'ct-ln';
        ln.textContent = String(i + 1);
        const code = document.createElement('span');
        code.className = 'ct-line-code';
        code.textContent = line;
        const chk = document.createElement('span');
        chk.className = 'ct-line-check';
        chk.textContent = '✓';
        row.append(ln, code, chk);
        acceptedEl.appendChild(row);
      });
    }

    function updateProgress() {
      const total = data.steps.length;
      const pct = Math.round((current / total) * 100);
      pctEl.textContent = `${pct}%`;
      fillEl.style.width = `${pct}%`;
      stepNumEl.textContent = String(Math.min(current + 1, total));
    }

    function updateGhost() {
      const sol = data.steps[current]?.solution ?? '';
      const val = input.value;
      typedEl.textContent = val;
      const matches = sol.startsWith(val);
      ghostEl.textContent = matches ? sol.slice(val.length) : '';
      fieldEl.classList.toggle('is-mismatch', !matches && val.length > 0);
      const remaining = matches ? sol.slice(val.length) : '';
      const chunk = remaining ? nextChunk(remaining).trim() : '';
      if (chunk) {
        suggestChip.textContent = chunk;
        suggestEl.hidden = false;
      } else {
        suggestEl.hidden = true;
      }
    }

    // Oculta todas las zonas interactivas; cada kind muestra las suyas.
    function resetRegions() {
      suggestEl.hidden = true;
      choicesEl.hidden = true;
      choicesEl.replaceChildren();
      predictEl.hidden = true;
      feedbackEl.hidden = true;
      feedbackEl.className = 'ct-feedback';
      feedbackEl.replaceChildren();
      hintEl.hidden = true;
      activeWrap.hidden = true;
      freeWrap.hidden = true;
      readonlyEl.hidden = true;
      checksEl.hidden = true;
      checksEl.replaceChildren();
      revealBtn.hidden = true;
      runBtn.hidden = true;
    }

    function setOutput(res: RunResult) {
      outEl.className = 'ct-console-out font-mono';
      if (res.loadFailed) {
        outEl.classList.add('ct-out-muted');
        outEl.textContent =
          '// tu código es correcto. (No se pudo cargar el motor de ejecución en este entorno para mostrar la salida.)';
        return;
      }
      if (res.incomplete) {
        outEl.classList.add('ct-out-muted');
        outEl.textContent = '// el programa todavía está incompleto…';
        return;
      }
      if (!res.ok) {
        outEl.classList.add('ct-out-err');
        outEl.textContent = res.output || 'Error al ejecutar';
        return;
      }
      if (!res.output) {
        outEl.classList.add('ct-out-muted');
        outEl.textContent = '// sin salida (este código no imprime nada todavía)';
        return;
      }
      outEl.textContent = res.output;
    }

    function setMutedOutput(text: string) {
      outEl.className = 'ct-console-out font-mono ct-out-muted';
      outEl.textContent = text;
    }

    // ── Carga de un paso según su kind ────────────────────────
    function loadStep() {
      const step = data.steps[current];
      if (!step) return;
      wrongThisStep = false;
      attemptsThisStep = 0;
      answered = false;
      resetRegions();

      instructionEl.textContent = step.question || step.instruction;
      setHTML(explanationEl, step.explanationHtml);
      bindTermsIn(explanationEl);
      hintEl.textContent = step.hint;
      kindBadge.textContent = KIND_LABEL[step.kind];
      kindBadge.hidden = false;
      hintBtn.hidden = !step.hint;
      primaryBtn.disabled = false;
      updateProgress();

      if (step.kind === 'type') loadTypeStep(step);
      else if (step.kind === 'info') loadInfoStep(step);
      else if (step.kind === 'quiz') loadChoiceStep(step, 'quiz');
      else if (step.kind === 'predict') loadPredictStep(step);
      else if (step.kind === 'fix') loadFixStep(step);
      else if (step.kind === 'challenge') loadChallengeStep(step);
    }

    // kind: type
    function loadTypeStep(step: Step) {
      activeWrap.hidden = false;
      primaryBtn.textContent = 'Comprobar';
      input.value = leadingWs(step.solution);
      input.disabled = false;
      updateGhost();
      input.focus();
      const end = input.value.length;
      input.setSelectionRange(end, end);
    }

    // kind: info
    function loadInfoStep(step: Step) {
      if (step.code) {
        readonlyEl.hidden = false;
        readonlyEl.textContent = step.code;
      }
      primaryBtn.textContent = current + 1 >= data.steps.length ? 'Terminar' : 'Entendido';
      primaryBtn.focus();
    }

    // kind: quiz / predict-mc
    function loadChoiceStep(step: Step, mode: 'quiz' | 'predict') {
      if (mode === 'predict' && step.code) {
        readonlyEl.hidden = false;
        readonlyEl.textContent = step.code;
        setMutedOutput('// ¿qué imprime? elegí una opción');
      }
      choicesEl.hidden = false;
      step.choices.forEach((c, i) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'ct-choice';
        btn.dataset.idx = String(i);
        const key = document.createElement('span');
        key.className = 'ct-choice-key';
        key.textContent = String.fromCharCode(65 + i);
        const body = document.createElement('span');
        setHTML(body, c.textHtml);
        btn.append(key, body);
        btn.addEventListener('click', () => answerChoice(step, i, mode));
        choicesEl.appendChild(btn);
      });
      primaryBtn.textContent = 'Continuar';
      primaryBtn.disabled = true; // hasta responder
    }

    function answerChoice(step: Step, idx: number, mode: 'quiz' | 'predict') {
      if (answered) return;
      answered = true;
      const chosen = step.choices[idx];
      if (!chosen.correct) wrongThisStep = true;
      const btns = [...choicesEl.querySelectorAll<HTMLButtonElement>('.ct-choice')];
      btns.forEach((b, i) => {
        b.disabled = true;
        if (step.choices[i].correct) b.classList.add('is-correct');
        if (i === idx && !step.choices[i].correct) b.classList.add('is-wrong');
      });
      const fb = chosen.feedbackHtml || (chosen.correct ? '¡Correcto!' : 'No es esa. Mirá la opción marcada.');
      feedbackEl.className = 'ct-feedback ' + (chosen.correct ? 'is-ok' : 'is-bad');
      setHTML(feedbackEl, `<span class="ct-feedback-title">${chosen.correct ? '✓ Correcto' : '✗ Revisá'}</span>` + fb);
      feedbackEl.hidden = false;
      bindTermsIn(feedbackEl);
      if (mode === 'predict' && step.code && data.runnable) {
        runProgram(data.language, step.code).then(setOutput);
      }
      primaryBtn.disabled = false;
      primaryBtn.focus();
    }

    // kind: predict (texto libre)
    function loadPredictStep(step: Step) {
      if (step.choices.length) {
        loadChoiceStep(step, 'predict');
        return;
      }
      if (step.code) {
        readonlyEl.hidden = false;
        readonlyEl.textContent = step.code;
      }
      predictEl.hidden = false;
      predictInput.value = '';
      setMutedOutput('// escribí lo que creés que imprime y comprobá');
      primaryBtn.textContent = 'Comprobar';
      predictInput.focus();
    }

    // kind: fix
    function loadFixStep(step: Step) {
      freeWrap.hidden = false;
      freeInput.value = step.buggyCode || step.starter || '';
      autosize(freeInput);
      runBtn.hidden = false;
      setMutedOutput('// arreglá el código y ejecutá para ver la salida');
      primaryBtn.textContent = 'Comprobar';
      freeInput.focus();
    }

    // kind: challenge
    function loadChallengeStep(step: Step) {
      freeWrap.hidden = false;
      freeInput.value = step.starter || '';
      autosize(freeInput);
      runBtn.hidden = false;
      renderChecks(step, null);
      setMutedOutput('// escribí tu solución y ejecutá');
      primaryBtn.textContent = 'Comprobar';
      if (step.referenceSolution) revealBtn.hidden = false;
      freeInput.focus();
    }

    function renderChecks(step: Step, results: { label: string; passed: boolean }[] | null) {
      if (!step.checks.length) {
        checksEl.hidden = true;
        return;
      }
      checksEl.hidden = false;
      checksEl.replaceChildren();
      step.checks.forEach((c, i) => {
        const li = document.createElement('li');
        const r = results?.[i];
        li.className = 'ct-check' + (r ? (r.passed ? ' is-pass' : ' is-fail') : '');
        const mark = document.createElement('span');
        mark.className = 'ct-check-mark';
        mark.textContent = r ? (r.passed ? '✓' : '·') : '·';
        const label = document.createElement('span');
        label.textContent = c.label;
        li.append(mark, label);
        checksEl.appendChild(li);
      });
    }

    // ── Resolver / avanzar ────────────────────────────────────
    function shake() {
      activeWrap.classList.remove('is-shake');
      void activeWrap.offsetWidth;
      activeWrap.classList.add('is-shake');
    }

    function xpForKind(kind: Kind): number {
      const base = (XP as Record<string, number>)[kind] ?? 4;
      return wrongThisStep ? Math.max(2, Math.round(base / 2)) : base;
    }

    function solveStep() {
      const step = data.steps[current];
      const gained = xpForKind(step.kind);
      addXp(gained, `${step.kind}:${data.lessonSlug}`);
      if (current === 0) unlock('first-step');
      if (step.kind === 'fix') {
        const n = bumpCounter('fixes');
        if (n >= 5) unlock('bug-hunter');
      }
      if (step.kind === 'challenge') {
        const n = bumpCounter('challenges');
        if (n >= 5) unlock('challenger');
      }
      const hour = new Date().getHours();
      if (hour >= 0 && hour < 5) unlock('night-owl');

      if (step.revealHtml && step.kind !== 'quiz' && step.kind !== 'predict') {
        feedbackEl.className = 'ct-feedback is-ok';
        setHTML(feedbackEl, `<span class="ct-feedback-title">✓ ¡Bien!</span>` + step.revealHtml);
        feedbackEl.hidden = false;
        bindTermsIn(feedbackEl);
      }

      current += 1;
      saveStep();
      if (current >= data.steps.length) {
        finishLesson();
      } else {
        loadStep();
      }
    }

    async function handlePrimary() {
      const step = data.steps[current];
      if (!step) return;

      if (step.kind === 'type') {
        if (norm(input.value) === norm(step.solution)) {
          accepted.push(step.solution);
          renderAccepted();
          if (data.runnable) {
            const partial = current + 1 < data.steps.length;
            const res = await runProgram(data.language, accepted.join('\n'));
            setOutput(res.incomplete && partial ? { ok: true, output: '', incomplete: true } : res);
          }
          solveStep();
        } else {
          wrongThisStep = true;
          shake();
          hintEl.hidden = false;
        }
        return;
      }

      if (step.kind === 'info') {
        solveStep();
        return;
      }

      if (step.kind === 'quiz' || (step.kind === 'predict' && step.choices.length)) {
        if (!answered) return;
        solveStep();
        return;
      }

      if (step.kind === 'predict') {
        const expected = normalizeOutput(step.expectedOutput);
        const got = normalizeOutput(predictInput.value);
        const ok = got === expected;
        if (data.runnable && step.code) {
          runProgram(data.language, step.code).then(setOutput);
        } else {
          outEl.className = 'ct-console-out font-mono';
          outEl.textContent = step.expectedOutput;
        }
        feedbackEl.className = 'ct-feedback ' + (ok ? 'is-ok' : 'is-bad');
        setHTML(
          feedbackEl,
          ok
            ? `<span class="ct-feedback-title">✓ ¡Exacto!</span>Esa es la salida.`
            : `<span class="ct-feedback-title">Casi</span>Comparalo con la salida real de la consola y reintentá.`
        );
        feedbackEl.hidden = false;
        if (!ok) {
          wrongThisStep = true;
          return;
        }
        solveStep();
        return;
      }

      if (step.kind === 'fix' || step.kind === 'challenge') {
        attemptsThisStep++;
        const code = freeInput.value;
        if (!data.runnable) {
          const ok = step.referenceSolution ? norm(code) === norm(step.referenceSolution) : !!step.expectedOutput;
          if (ok) solveStep();
          return;
        }
        const res = await runProgram(data.language, code);
        setOutput(res);
        let pass = false;
        if (step.checks.length) {
          const results = evaluateChecks(res.output, step.checks as Check[]);
          renderChecks(step, results);
          pass = res.ok && results.every((r) => r.passed);
        } else if (step.expectedOutput) {
          pass = res.ok && normalizeOutput(res.output) === normalizeOutput(step.expectedOutput);
        } else {
          pass = res.ok;
        }
        if (pass) {
          solveStep();
        } else {
          wrongThisStep = true;
          feedbackEl.className = 'ct-feedback is-bad';
          setHTML(
            feedbackEl,
            !res.ok && !res.incomplete
              ? `<span class="ct-feedback-title">Hay un error</span>Mirá el mensaje en la consola y ajustá el código.`
              : `<span class="ct-feedback-title">Todavía no</span>La salida no cumple lo pedido. Revisá las comprobaciones.`
          );
          feedbackEl.hidden = false;
          if (attemptsThisStep >= 2 && step.referenceSolution) revealBtn.hidden = false;
        }
        return;
      }
    }

    function finishLesson() {
      finished = true;
      const isNew = markLessonDone(data.courseSlug, data.lessonSlug, data.tags);
      if (isNew) addXp(XP.lessonBonus, 'lesson-bonus');
      else gradeReview(`${data.courseSlug}/${data.lessonSlug}`, true); // repaso superado
      unlock('first-lesson');
      const li = getLevelInfo();
      if (li.level >= 5) unlock('level-5');
      const st = liveStreak();
      if (st.count >= 3) unlock('streak-3');
      if (st.count >= 7) unlock('streak-7');
      if (data.courseSlug === 'ia' || data.courseSlug.startsWith('ia')) unlock('ai-aware');

      activeWrap.hidden = true;
      freeWrap.hidden = true;
      readonlyEl.hidden = true;
      suggestEl.hidden = true;
      choicesEl.hidden = true;
      predictEl.hidden = true;
      instructionEl.textContent = '¡Lección completada!';
      kindBadge.hidden = true;
      setHTML(
        explanationEl,
        data.runnable
          ? 'Repasá tu trabajo a la derecha. Podés editar y volver a ejecutar con <strong>Ejecutar</strong>.'
          : 'Buen trabajo. Avanzá a la próxima lección cuando quieras.'
      );
      feedbackEl.hidden = true;
      hintEl.hidden = true;
      hintBtn.hidden = true;
      revealBtn.hidden = true;
      primaryBtn.hidden = true;
      updateProgress();
      pctEl.textContent = '100%';
      fillEl.style.width = '100%';
      const li2 = getLevelInfo();
      doneSub.textContent = isNew
        ? `+${XP.lessonBonus} XP de bonus · Nivel ${li2.level} · ${li2.rank}`
        : `Ya la habías completado. Nivel ${li2.level} · ${li2.rank}`;
      doneEl.hidden = false;
      if (data.runnable && accepted.length) {
        runBtn.hidden = false;
        makeEditable();
        runProgram(data.language, accepted.join('\n')).then(setOutput);
      }
      const nextHref = root.getAttribute('data-next-href');
      if (nextHref) {
        doneNext.href = nextHref;
        doneNext.hidden = false;
      }
    }

    // Editor libre tras completar (para cursos con código acumulado).
    function makeEditable() {
      acceptedEl.replaceChildren();
      freeWrap.hidden = false;
      freeInput.value = accepted.join('\n');
      autosize(freeInput);
      runBtn.onclick = () => runProgram(data.language, freeInput.value).then(setOutput);
    }

    function autosize(ta: HTMLTextAreaElement) {
      ta.style.height = 'auto';
      ta.style.height = Math.max(ta.scrollHeight, 144) + 'px';
    }

    // ── Glosario (tooltips) ─────────────────────────────────────
    function bindTermsIn(scope: HTMLElement) {
      scope.querySelectorAll<HTMLElement>('.ct-term').forEach((btn) => {
        if (btn.dataset.bound === '1') return;
        btn.dataset.bound = '1';
        const key = btn.dataset.term || '';
        const entry = data.glossary[key];
        if (!entry) return;
        const show = () => {
          tipTerm.textContent = entry.term;
          tipDef.textContent = entry.definition;
          tipEl.hidden = false;
          const r = btn.getBoundingClientRect();
          const tr = tipEl.getBoundingClientRect();
          let left = r.left + r.width / 2 - tr.width / 2;
          left = Math.max(8, Math.min(left, window.innerWidth - tr.width - 8));
          let top = r.top - tr.height - 8;
          if (top < 8) top = r.bottom + 8;
          tipEl.style.left = `${left}px`;
          tipEl.style.top = `${top}px`;
        };
        const hide = () => {
          tipEl.hidden = true;
        };
        btn.addEventListener('mouseenter', show);
        btn.addEventListener('mouseleave', hide);
        btn.addEventListener('focus', show);
        btn.addEventListener('blur', hide);
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          if (tipEl.hidden) show();
          else hide();
        });
      });
    }

    function acceptChunk() {
      const sol = data.steps[current]?.solution ?? '';
      const val = input.value;
      if (!sol.startsWith(val)) return;
      const remaining = sol.slice(val.length);
      if (!remaining) return;
      input.value = val + nextChunk(remaining);
      updateGhost();
      const end = input.value.length;
      input.setSelectionRange(end, end);
    }

    // ── Eventos ─────────────────────────────────────────────────
    input.addEventListener('input', updateGhost);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Tab') {
        e.preventDefault();
        acceptChunk();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        handlePrimary();
      }
    });
    suggestChip.addEventListener('click', () => {
      acceptChunk();
      input.focus();
    });
    freeInput.addEventListener('keydown', (e) => {
      if (e.key === 'Tab') {
        e.preventDefault();
        const s = freeInput.selectionStart;
        const en = freeInput.selectionEnd;
        freeInput.value = freeInput.value.slice(0, s) + '  ' + freeInput.value.slice(en);
        freeInput.selectionStart = freeInput.selectionEnd = s + 2;
      }
    });
    freeInput.addEventListener('input', () => autosize(freeInput));
    predictInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        handlePrimary();
      }
    });
    primaryBtn.addEventListener('click', () => handlePrimary());
    hintBtn.addEventListener('click', () => {
      hintEl.hidden = !hintEl.hidden;
    });
    revealBtn.addEventListener('click', () => {
      const step = data.steps[current];
      if (step?.referenceSolution) {
        freeInput.value = step.referenceSolution;
        autosize(freeInput);
        freeInput.focus();
      }
    });
    runBtn.addEventListener('click', async () => {
      const step = data.steps[current];
      if (!finished && (step?.kind === 'fix' || step?.kind === 'challenge')) {
        setMutedOutput('// ejecutando…');
        const res = await runProgram(data.language, freeInput.value);
        setOutput(res);
        if (step.kind === 'challenge' && step.checks.length) {
          renderChecks(step, evaluateChecks(res.output, step.checks as Check[]));
        }
      }
    });
    resetBtn.addEventListener('click', () => {
      accepted.length = 0;
      current = 0;
      finished = false;
      clearLesson(data.courseSlug, data.lessonSlug);
      acceptedEl.replaceChildren();
      doneEl.hidden = true;
      doneNext.hidden = true;
      hintBtn.hidden = false;
      primaryBtn.hidden = false;
      runBtn.onclick = null;
      setMutedOutput('// la salida de tu programa aparece acá');
      loadStep();
    });
    window.addEventListener('scroll', () => (tipEl.hidden = true), { passive: true });

    // ── Arranque ────────────────────────────────────────────────
    renderAccepted();
    loadStep();
    setMutedOutput(data.runnable ? '// la salida de tu programa aparece acá' : '// lección conceptual');
  }

  function initAll() {
    document.querySelectorAll<HTMLElement>('[data-ct]').forEach(initTutor);
  }

  document.addEventListener('astro:page-load', initAll);
  if (document.readyState !== 'loading') initAll();
  else document.addEventListener('DOMContentLoaded', initAll);
</script>
