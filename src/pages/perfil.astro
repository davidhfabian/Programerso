---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Mi perfil" description="Tu cuenta, avatar y certificados en Programerso.">
  <section class="max-w-xl mx-auto px-4 sm:px-6 pt-12 md:pt-16 pb-20">
    {/* ── Invitado: invitar a crear cuenta ───────────────────── */}
    <div data-pf-guest hidden>
      <p class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-[var(--aw-color-text-tertiary)] mb-2">Cuenta</p>
      <h1 class="font-heading text-3xl font-semibold tracking-tight text-default mb-3">Estás como invitado</h1>
      <p class="text-muted leading-relaxed mb-6 text-[0.95rem]">
        Podés aprender sin cuenta, pero tu progreso queda atado a este navegador. <strong class="text-default">Creá una
        cuenta</strong> para no perderlo y desbloquear tus certificados con tu nombre.
      </p>
      <div class="flex flex-wrap gap-3 mb-8">
        <a href="/registro" class="btn-primary">Crear cuenta gratis</a>
        <a href="/entrar" class="inline-flex items-center text-sm rounded-lg border border-[var(--aw-color-border)] hover:border-[var(--aw-color-border-hover)] px-5 py-3 text-default transition-colors">
          Ya tengo cuenta
        </a>
      </div>
      <div class="rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-surface)] p-5">
        <p class="text-[0.82rem] text-muted mb-3">Tu progreso como invitado:</p>
        <div class="flex items-center gap-6 text-sm">
          <div><span class="text-2xl font-semibold text-default" data-pf-guest-xp>0</span> <span class="text-muted">XP</span></div>
          <div><span class="text-2xl font-semibold text-default" data-pf-guest-lessons>0</span> <span class="text-muted">lecciones</span></div>
        </div>
      </div>
    </div>

    {/* ── Cuenta ─────────────────────────────────────────────── */}
    <div data-pf-account hidden>
      <p class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-[var(--aw-color-text-tertiary)] mb-2">Cuenta</p>
      <h1 class="font-heading text-3xl font-semibold tracking-tight text-default mb-6">Tu perfil</h1>

      <div class="rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-surface)] p-6 mb-6">
        <div class="flex items-center gap-4">
          <div class="grid place-items-center w-16 h-16 rounded-2xl bg-[var(--turquoise-bg)] border border-[var(--turquoise-border)] text-3xl" data-pf-avatar>🦊</div>
          <div class="min-w-0">
            <h2 class="font-heading text-xl font-semibold text-default truncate" data-pf-display>—</h2>
            <p class="text-[0.82rem] text-muted truncate" data-pf-email>—</p>
            <p class="text-[0.78rem] text-[var(--aw-color-text-tertiary)] mt-0.5">
              Nivel <span data-pf-level>1</span> · <span data-pf-rank>Curioso</span> · <span data-pf-xp>0</span> XP
            </p>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3 mb-6">
        <a href="/progreso" class="rounded-xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-surface)] p-4 text-center hover:border-[var(--aw-color-border-hover)] transition-colors">
          <Icon name="tabler:flame" class="w-5 h-5 mx-auto mb-1.5 text-primary" />
          <div class="text-xl font-semibold text-default" data-pf-streak>0</div>
          <div class="text-[0.68rem] text-muted">racha</div>
        </a>
        <a href="/progreso" class="rounded-xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-surface)] p-4 text-center hover:border-[var(--aw-color-border-hover)] transition-colors">
          <Icon name="tabler:books" class="w-5 h-5 mx-auto mb-1.5 text-primary" />
          <div class="text-xl font-semibold text-default" data-pf-lessons>0</div>
          <div class="text-[0.68rem] text-muted">lecciones</div>
        </a>
        <a href="/progreso" class="rounded-xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-surface)] p-4 text-center hover:border-[var(--aw-color-border-hover)] transition-colors">
          <Icon name="tabler:trophy" class="w-5 h-5 mx-auto mb-1.5 text-primary" />
          <div class="text-xl font-semibold text-default" data-pf-ach>0</div>
          <div class="text-[0.68rem] text-muted">logros</div>
        </a>
      </div>

      <div class="rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-surface)] p-6 mb-6">
        <h3 class="text-sm font-semibold text-default mb-4">Editar</h3>
        <div class="flex items-end gap-3">
          <div class="flex-1">
            <label class="block text-[0.8rem] text-muted mb-1.5" for="pf-rename">Nombre</label>
            <input id="pf-rename" type="text" maxlength="40" data-pf-rename
              class="w-full rounded-lg border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] px-3.5 py-2.5 text-default outline-none focus:border-[var(--aw-color-primary)]" />
          </div>
          <button type="button" data-pf-save class="btn-primary shrink-0">Guardar</button>
        </div>
        <div class="mt-4">
          <label class="block text-[0.8rem] text-muted mb-1.5">Avatar</label>
          <div class="flex flex-wrap gap-2" data-pf-avatars-edit></div>
        </div>
      </div>

      <div class="rounded-2xl border border-[var(--aw-color-border)] p-6 mb-6">
        <h3 class="text-sm font-semibold text-default mb-1">Certificados</h3>
        <p class="text-[0.82rem] text-muted mb-4">Completá un curso para desbloquear su diploma con tu nombre.</p>
        <div class="space-y-2" data-pf-certs></div>
      </div>

      <details class="rounded-2xl border border-[var(--aw-color-border)] p-5 mb-6">
        <summary class="cursor-pointer text-sm font-semibold text-default">Tus datos</summary>
        <p class="text-[0.82rem] text-muted mt-3 mb-4">Exportá tu progreso para respaldarlo o llevarlo a otro dispositivo.</p>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-pf-export class="inline-flex items-center gap-2 text-sm rounded-lg border border-[var(--aw-color-border)] hover:border-[var(--aw-color-border-hover)] px-3 py-2 text-default transition-colors">
            <Icon name="tabler:download" class="w-4 h-4" /> Exportar
          </button>
          <label class="inline-flex items-center gap-2 text-sm rounded-lg border border-[var(--aw-color-border)] hover:border-[var(--aw-color-border-hover)] px-3 py-2 text-default transition-colors cursor-pointer">
            <Icon name="tabler:arrow-up" class="w-4 h-4" /> Importar
            <input type="file" accept="application/json" class="hidden" data-pf-import />
          </label>
        </div>
      </details>

      <button type="button" data-pf-logout class="text-[0.85rem] inline-flex items-center gap-2 text-muted hover:text-default transition-colors">
        <Icon name="tabler:lock" class="w-4 h-4" /> Cerrar sesión
      </button>
    </div>
  </section>
</Layout>

<script>
  import { currentUser, logout, updateName } from '~/lib/auth';
  import {
    getLevelInfo, getXp, liveStreak, getAchievements, getDone,
    getAvatar, setAvatar, exportProgress, importProgress, today,
  } from '~/lib/store';

  const AVATARS = ['🦊', '🐙', '🦉', '🐢', '🚀', '🤖', '🐝', '🦄', '🐬', '🐧', '🦁', '👾'];
  const COURSES = [
    { slug: 'ia', title: 'Programar en la era de la IA' },
    { slug: 'javascript', title: 'JavaScript desde cero' },
    { slug: 'python', title: 'Python desde cero' },
  ];

  function setup() {
    const guestEl = document.querySelector<HTMLElement>('[data-pf-guest]');
    const accountEl = document.querySelector<HTMLElement>('[data-pf-account]');
    if (!guestEl || !accountEl) return;
    const user = currentUser();
    const set = (sel: string, t: string) => { const el = document.querySelector(sel); if (el) el.textContent = t; };

    let totalDone = 0;
    for (const c of COURSES) totalDone += getDone(c.slug).size;

    if (!user) {
      guestEl.hidden = false;
      accountEl.hidden = true;
      set('[data-pf-guest-xp]', String(getXp()));
      set('[data-pf-guest-lessons]', String(totalDone));
      return;
    }

    accountEl.hidden = false;
    guestEl.hidden = true;

    const li = getLevelInfo();
    const st = liveStreak();
    let avatar = getAvatar();
    set('[data-pf-display]', user.name);
    set('[data-pf-email]', user.email);
    set('[data-pf-level]', String(li.level));
    set('[data-pf-rank]', li.rank);
    set('[data-pf-xp]', String(getXp()));
    set('[data-pf-streak]', String(st.count));
    set('[data-pf-ach]', String(getAchievements().size));
    set('[data-pf-lessons]', String(totalDone));
    const avatarEl = document.querySelector<HTMLElement>('[data-pf-avatar]');
    if (avatarEl) avatarEl.textContent = avatar;
    const renameEl = document.querySelector<HTMLInputElement>('[data-pf-rename]');
    if (renameEl) renameEl.value = user.name;

    // Avatares
    const gallery = document.querySelector<HTMLElement>('[data-pf-avatars-edit]');
    if (gallery) {
      gallery.replaceChildren();
      AVATARS.forEach((a) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'w-10 h-10 rounded-xl border border-[var(--aw-color-border)] text-xl grid place-items-center hover:border-[var(--aw-color-border-hover)]';
        b.textContent = a;
        if (a === avatar) b.classList.add('!border-[var(--turquoise-border)]', 'bg-[var(--turquoise-bg)]');
        b.addEventListener('click', () => {
          setAvatar(a); avatar = a;
          if (avatarEl) avatarEl.textContent = a;
          gallery.querySelectorAll('button').forEach((x) => x.classList.remove('!border-[var(--turquoise-border)]', 'bg-[var(--turquoise-bg)]'));
          b.classList.add('!border-[var(--turquoise-border)]', 'bg-[var(--turquoise-bg)]');
        });
        gallery.appendChild(b);
      });
    }

    document.querySelector('[data-pf-save]')?.addEventListener('click', () => {
      const name = (renameEl?.value || '').trim();
      if (name) { updateName(name); set('[data-pf-display]', name); }
    });

    // Certificados
    const certs = document.querySelector<HTMLElement>('[data-pf-certs]');
    if (certs) {
      certs.replaceChildren();
      for (const c of COURSES) {
        const done = getDone(c.slug).size;
        const row = document.createElement('div');
        row.className = 'flex items-center justify-between gap-3 rounded-lg border border-[var(--aw-color-border)] px-4 py-3';
        const label = document.createElement('span');
        label.className = 'text-[0.88rem] text-default';
        label.textContent = c.title;
        row.appendChild(label);
        const link = document.createElement('a');
        if (done > 0) {
          link.href = `/certificado/${c.slug}`;
          link.className = 'text-[0.82rem] text-primary hover:underline';
          link.textContent = 'Ver diploma →';
        } else {
          link.className = 'text-[0.82rem] text-[var(--aw-color-text-tertiary)]';
          link.textContent = 'Bloqueado';
        }
        row.appendChild(link);
        certs.appendChild(row);
      }
    }

    // Datos
    document.querySelector('[data-pf-export]')?.addEventListener('click', () => {
      const blob = new Blob([exportProgress()], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = `programerso-${user.name}-${today()}.json`; a.click();
      URL.revokeObjectURL(url);
    });
    const importInput = document.querySelector<HTMLInputElement>('[data-pf-import]');
    importInput?.addEventListener('change', () => {
      const file = importInput.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => {
        if (importProgress(String(reader.result))) location.reload();
        else alert('No se pudo importar: archivo inválido.');
      };
      reader.readAsText(file);
    });

    document.querySelector('[data-pf-logout]')?.addEventListener('click', () => {
      logout();
      location.href = '/';
    });
  }
  document.addEventListener('astro:page-load', setup);
  if (document.readyState !== 'loading') setup();
  else document.addEventListener('DOMContentLoaded', setup);
</script>
