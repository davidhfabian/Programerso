---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import { glossary } from '~/data/learn';

const entries = Object.entries(glossary).sort((a, b) => a[1].term.localeCompare(b[1].term, 'es'));
---

<Layout title="Glosario" description="Todos los términos de programación de Programerso, explicados en simple.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pt-12 md:pt-16 pb-20">
    <p class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-[var(--aw-color-text-tertiary)] mb-2">Referencia</p>
    <h1 class="font-heading text-3xl md:text-4xl font-semibold tracking-tight text-default mb-3">Glosario</h1>
    <p class="text-muted leading-relaxed mb-7 text-[0.95rem]">
      Cada término que aparece en los cursos, explicado en palabras simples. {entries.length} conceptos.
    </p>

    <div class="sticky top-[4.2rem] z-10 mb-6 bg-[var(--aw-color-bg-page)]/90 backdrop-blur py-2">
      <input
        type="search"
        placeholder="Filtrar términos…"
        data-glos-filter
        aria-label="Filtrar términos"
        class="w-full rounded-xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-surface)] px-4 py-3 text-default outline-none focus:border-[var(--aw-color-primary)]"
      />
    </div>

    <div class="grid gap-3" data-glos-list>
      {
        entries.map(([key, entry]) => (
          <article
            id={key}
            class="glos-item scroll-mt-24 rounded-xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-surface)] p-5"
            data-term={`${entry.term} ${entry.definition}`.toLowerCase()}
          >
            <h2 class="text-base font-semibold text-default mb-1">{entry.term}</h2>
            <p class="text-[0.9rem] text-muted leading-relaxed">{entry.definition}</p>
          </article>
        ))
      }
    </div>
    <p class="text-center text-muted text-sm mt-8" data-glos-empty hidden>Ningún término coincide con tu búsqueda.</p>
  </section>
</Layout>

<script>
  function setup() {
    const filter = document.querySelector<HTMLInputElement>('[data-glos-filter]');
    const items = [...document.querySelectorAll<HTMLElement>('.glos-item')];
    const empty = document.querySelector<HTMLElement>('[data-glos-empty]');
    if (!filter) return;
    const norm = (s: string) => s.toLowerCase().normalize('NFD').replace(/\p{Diacritic}/gu, '');
    filter.addEventListener('input', () => {
      const q = norm(filter.value.trim());
      let visible = 0;
      items.forEach((it) => {
        const hit = !q || norm(it.dataset.term || '').includes(q);
        it.hidden = !hit;
        if (hit) visible++;
      });
      if (empty) empty.hidden = visible > 0;
    });
    // Resaltar el término si se llega con #ancla
    if (location.hash) {
      const el = document.querySelector(location.hash);
      el?.classList.add('border-[var(--turquoise-border)]', 'bg-[var(--turquoise-bg)]');
    }
  }
  document.addEventListener('astro:page-load', setup);
  if (document.readyState !== 'loading') setup();
  else document.addEventListener('DOMContentLoaded', setup);
</script>
